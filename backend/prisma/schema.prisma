// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../src/generated/zod" // Saves Zod schemas separate from Prisma types
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  VENDOR
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  /// @zod.string.min(2, { message: "Name must be at least 2 characters long" })
  name      String
  /// @zod.string.regex(/^\+?[1-9]\d{1,14}$/, { message: "Invalid phone number format" })
  phone     String   @unique
  address   String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor          Vendor?           @relation("VendorIdRelation")
  vendorcustomers VendorCustomers[] @relation("CustomerPhoneRelation")
}

model Vendor {
  id            String   @id @default(uuid())
  userId        String   @unique
  /// @zod.string.min(2,{message: "Business name must be at least 2 characters long"})
  businessName  String
  /// @zod.string.regex(/^\+?[1-9]\d{1,14}$/, { message: "Invalid phone number format" })
  businessPhone String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation("VendorIdRelation", fields: [userId], references: [id], onDelete: Cascade)

  product Product[]

  vendorcustomers VendorCustomers[]
}

model Product {
  id          String   @id @default(uuid())
  vendorId    String
  /// @zod.string.min(2,{message: "Product name must be of at least 2 characters"})
  productName String
  /// @zod.string.min(2, {message: "Product description must be of at leat 2 characters"})
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  subscription CustomerSubscription[]
  request Requests[]
}

model VendorCustomers {
  id            String   @id @default(uuid())
  vendorId      String
  /// @zod.string.regex(/^\+?[1-9]\d{1,14}$/, { message: "Invalid phone number format" })
  customerPhone String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation("CustomerPhoneRelation", fields: [customerPhone], references: [phone], onDelete: Cascade)

  subscription CustomerSubscription[]
  request Requests[]

  @@unique([vendorId, customerPhone])
}

model CustomerSubscription {
  id               String   @id @default(uuid())
  vendorCustomerId String
  productId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  vendorCustomers VendorCustomers @relation(fields: [vendorCustomerId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

   @@unique([vendorCustomerId, productId]) 
}

model Requests {
  id String @id @default(uuid())
  vendorCustomerId String
  productId String
  type String @default("note")
  /// @zod.string.min(2,{message: "Message should be at least 2 of 2 characters"})
  message String 
  start_date DateTime
  end_date DateTime
  status Status @default(PENDING)
  respondedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorCustomers VendorCustomers @relation(fields: [vendorCustomerId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

}